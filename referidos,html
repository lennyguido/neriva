    <p>Llegaste con el código de:</p>
    <strong id="refBannerCodigo"></strong>
    <p style="margin-top:0.3rem;font-size:0.7rem;color:#555">Al comprar, se lo mencionamos al vendedor.</p>
</div>

<script>
const WA_NUMBER = '5491128330853';
const REF_KEY = 'neriva_ref_codigo';
const MAX_CODIGO_LENGTH = 16;
const RATE_LIMIT_ATTEMPTS = 3;
const RATE_LIMIT_WINDOW = 60000;
let rateLimitMap = {};

function checkRateLimit(key){
    const now=Date.now();
    if(!rateLimitMap[key]) rateLimitMap[key]={count:0,resetTime:now+RATE_LIMIT_WINDOW};
    const e=rateLimitMap[key];
    if(now>e.resetTime){e.count=0;e.resetTime=now+RATE_LIMIT_WINDOW;}
    if(e.count>=RATE_LIMIT_ATTEMPTS) return false;
    e.count++;return true;
}

function sanitizeCodigo(raw){
    if(typeof raw!=='string') return '';
    return raw.trim().toUpperCase().replace(/[^A-Z0-9]/g,'').substring(0,MAX_CODIGO_LENGTH);
}

function encryptData(key,value){
    try{localStorage.setItem(key+'_enc',btoa(JSON.stringify({key,value,ts:Date.now()})));}catch(e){}
}
function decryptData(key){
    try{const r=localStorage.getItem(key+'_enc');if(!r)return null;return JSON.parse(atob(r)).value;}catch(e){localStorage.removeItem(key+'_enc');return null;}
}

function getLinkReferido(codigo){
    const base=window.location.href.split('?')[0].replace('referidos.html','index.html');
    return base+'?ref='+sanitizeCodigo(codigo);
}

function crearCodigo(){
    if(!checkRateLimit('crear_codigo')){document.getElementById('refError').textContent='Demasiados intentos. Esperá 1 minuto.';return;}
    const input=document.getElementById('refInput');
    const errorEl=document.getElementById('refError');
    const codigo=sanitizeCodigo(input.value);
    if(codigo.length<3){input.classList.add('error');errorEl.textContent='Al menos 3 caracteres.';setTimeout(()=>input.classList.remove('error'),600);return;}
    errorEl.textContent='';
    encryptData(REF_KEY,codigo);
    mostrarCodigoActivo(codigo);
}

function mostrarCodigoActivo(codigo){
    const s=codigo.toUpperCase();
    document.getElementById('refCodigoLabel').textContent='TU CÓDIGO: '+s;
    document.getElementById('refLinkDisplay').textContent=getLinkReferido(s);
    document.getElementById('refCrear').style.display='none';
    document.getElementById('refActivo').style.display='block';
}

function cambiarCodigo(){
    localStorage.removeItem(REF_KEY+'_enc');
    document.getElementById('refCrear').style.display='block';
    document.getElementById('refActivo').style.display='none';
    document.getElementById('refInput').value='';
    document.getElementById('refError').textContent='';
}

function copiarLink(){
    const link=document.getElementById('refLinkDisplay').textContent;
    navigator.clipboard.writeText(link).then(()=>{
        const btn=document.getElementById('btnCopiarLink');
        btn.textContent='✅ ¡Copiado!';btn.classList.add('copiado');
        setTimeout(()=>{btn.textContent='📋 Copiar link';btn.classList.remove('copiado');},2000);
    }).catch(()=>alert('No se pudo copiar.'));
}

function shareWhatsapp(){
    const codigo=decryptData(REF_KEY);if(!codigo)return;
    window.open('https://wa.me/?text='+encodeURIComponent('Te recomiendo esta tienda! Entrá con mi link: '+getLinkReferido(sanitizeCodigo(codigo))),'_blank');
}
function shareInstagram(){
    const codigo=decryptData(REF_KEY);if(!codigo)return;
    navigator.clipboard.writeText(getLinkReferido(sanitizeCodigo(codigo))).then(()=>alert('Link copiado! Pegalo en tu bio o historia de Instagram.'));
}

function toggleFaq(btn){
    const item=btn.closest('.faq-item');
    const wasOpen=item.classList.contains('open');
    document.querySelectorAll('.faq-item').forEach(i=>i.classList.remove('open'));
    if(!wasOpen) item.classList.add('open');
}

// Init referidos
(function(){
    const guardado=decryptData(REF_KEY);
    if(guardado) mostrarCodigoActivo(guardado);
    const params=new URLSearchParams(window.location.search);
    const refEntrante=params.get('ref');
    if(refEntrante){
        const limpio=sanitizeCodigo(refEntrante);
        if(limpio){
            sessionStorage.setItem('neriva_ref_por',limpio);
            document.getElementById('refBannerCodigo').textContent=limpio;
            document.getElementById('refBanner').classList.add('visible');
            setTimeout(()=>document.getElementById('refBanner').classList.remove('visible'),8000);
        }
    }
})();

document.getElementById('refInput').addEventListener('input',function(){
    this.value=sanitizeCodigo(this.value);
    document.getElementById('refError').textContent='';
    this.classList.remove('error');
});
document.getElementById('refInput').addEventListener('keydown',e=>{if(e.key==='Enter')crearCodigo();});

// Scroll reveal
const revealObserver=new IntersectionObserver(entries=>{
    entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('visible');revealObserver.unobserve(e.target);}});
},{threshold:0.08});
document.querySelectorAll('.reveal').forEach(el=>revealObserver.observe(el));
</script>
